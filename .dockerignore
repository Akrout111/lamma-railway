# Version control
.git
.gitignore
.gitattributes

# Dependencies (will be installed in Docker)
node_modules
**/node_modules

# Build artifacts
.next
out
build
dist

# Environment files (secrets!)
.env
.env.local
.env.*.local
.env.production
.env.development

# Database (local dev only)
db/*.db
db/*.db-journal

# Logs
*.log
dev.log
server.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDE / OS
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db

# Documentation (not needed in image)
README.md
CHANGELOG.md
docs/

# CI / CD (not needed in image)
.github
.gitlab-ci.yml

# Docker files themselves (don't include in image)
Dockerfile
.dockerignore
docker-compose.yml
docker-compose.*.yml

# Railway config (not needed inside image)
railway.json
railway.toml

# Sandbox-only files (not needed in production)
.zscripts
examples
tool-results
upload
download
reference
skills
worklog.md
.claude
.z-ai-config

# Test files
coverage
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__
__mocks__

# Misc
*.md
!prisma/seed-standalone.ts
LICENSE

// ============================================================================
//  Lamma — Prisma Schema (Phase B — PostgreSQL + pgvector)
//
//  Target: Supabase PostgreSQL with pgvector + pg_trgm extensions.
//
//  Type mapping (from Phase A SQLite):
//    String (JSON)        → Json           (name, bio, displayName, etc.)
//    String (joined |)    → String[]       (interests, specialties, topicSlugs)
//    String? (mock vec)   → Unsupported("vector(1536)")?  (embedding)
//    Float (KWD)          → Decimal @db.Decimal(10,3)
//    String (date)        → DateTime @db.Date
//    String (long text)   → String @db.Text
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector, pg_trgm]
}

// ----------------------------------------------------------------------------
//  User — synced from Clerk via webhook (id = Clerk userId)
// ----------------------------------------------------------------------------
model User {
  id              String   @id // Clerk userId (no auto-generation)
  email           String   @unique
  phone           String?  @unique
  passwordHash    String   @default("") // unused with Clerk, kept for compat

  name            Json     // { ar: "...", en: "..." }
  bio             Json?    // { ar: "...", en: "..." }
  avatarUrl       String?
  dateOfBirth     DateTime?
  gender          String?  // "male" | "female"
  nationality     String?

  interests       String[] // ["photography", "art", ...]
  embedding       Unsupported("vector(1536)")?

  membershipTier  String   @default("NEWCOMER") // NEWCOMER | REGULAR | CURATOR | HOST
  hostedCount     Int      @default(0)
  attendedCount   Int      @default(0)

  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  locale          String   @default("ar") // ar | en

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  host            Host?
  applications    Application[]
  memberships     Membership[]
  reviewsGiven    Review[]         @relation("ReviewReviewer")
  notifications   Notification[]
  messagesSent    Message[]        @relation("MessageSender")
  messagesRecv    Message[]        @relation("MessageReceiver")
  matchesA        AttendeeMatch[]  @relation("MatchUserA")
  matchesB        AttendeeMatch[]  @relation("MatchUserB")
  waitlist        WaitlistEntry[]

  @@index([membershipTier])
  @@index([gender])
}

// ----------------------------------------------------------------------------
//  Host — a curated User who can host gatherings
// ----------------------------------------------------------------------------
model Host {
  id              String   @id @default(cuid())
  userId          String   @unique
  handle          String   @unique // @handle, e.g. @abdullah_kuwaiti_historian

  displayName     Json     // { ar, en }
  bio             Json     // { ar, en }
  avatarUrl       String?
  coverUrl        String?
  isVerified      Boolean  @default(false)
  verifiedAt      DateTime?

  specialties     Json[]   // [{ ar, en }, ...]
  topicSlugs      String[] // ["memory-of-place", "food-stories", ...]

  totalGatherings Int      @default(0)
  totalAttendees  Int      @default(0)
  avgRating       Float    @default(0) // 0..5
  responseTimeHours Int    @default(24)
  instagram       String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gatherings      Gathering[]
  letters         Letter[]

  @@index([isVerified])
}

// ----------------------------------------------------------------------------
//  Topic — editorial theme (seeded, rarely written)
// ----------------------------------------------------------------------------
model Topic {
  id              String   @id @default(cuid())
  slug            String   @unique // memory-of-place, food-stories, ...
  name            Json     // { ar, en }
  description     Json     // { ar, en }
  color           String   @default("#B85C3E") // hex
  coverImageUrl   String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  gatherings      Gathering[]
  letters         Letter[]

  @@index([slug])
}

// ----------------------------------------------------------------------------
//  Gathering — the core entity
// ----------------------------------------------------------------------------
model Gathering {
  id              String   @id @default(cuid())
  slug            String   @unique

  title           Json     // { ar, en }
  description     Json     // { ar, en }
  coverImageUrl   String?
  galleryUrls     String[] // ["url1", "url2", ...]

  startDate       DateTime
  endDate         DateTime
  isPrayerAware   Boolean  @default(true)

  venueName       Json     // { ar, en }
  venueAddress    Json     // { ar, en }
  venueLat        Float
  venueLng        Float
  venueNotes      Json?    // { ar, en }

  format          String   @default("MIXED") // MEN_ONLY | WOMEN_ONLY | FAMILY | MIXED
  capacityMin     Int      @default(5)
  capacityMax     Int      @default(20)
  priceKwd        Decimal  @default(0) @db.Decimal(10, 3) // KWD 3-decimal precision
  isFree          Boolean  @default(false)

  applicationQuestions Json? // [{ id, question: {ar,en}, type, required, options? }]
  status          String   @default("DRAFT") // DRAFT | PUBLISHED | APPLICATIONS_OPEN | APPLICATIONS_CLOSED | IN_PROGRESS | COMPLETED | CANCELLED
  applicationsOpenAt   DateTime?
  applicationsCloseAt  DateTime?

  approvedAttendeesCount Int @default(0)

  hostId          String
  topicId         String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  host            Host     @relation(fields: [hostId], references: [id], onDelete: Cascade)
  topic           Topic    @relation(fields: [topicId], references: [id], onDelete: Restrict)
  applications    Application[]
  waitlist        WaitlistEntry[]
  letters         Letter[]
  moments         Moment[]
  reviews         Review[]

  @@index([status])
  @@index([startDate])
  @@index([hostId])
  @@index([topicId])
}

// ----------------------------------------------------------------------------
//  Application — a user applying to join a gathering
// ----------------------------------------------------------------------------
model Application {
  id              String   @id @default(cuid())
  userId          String
  gatheringId     String

  answers         Json     // [{ questionId, answer: {ar,en} }] or { questionId: answer }
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED | WAITLISTED | CANCELLED
  note            String?  @db.Text

  reviewedAt      DateTime?
  reviewedBy      String? // host userId

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gathering       Gathering @relation(fields: [gatheringId], references: [id], onDelete: Cascade)

  @@unique([userId, gatheringId])
  @@index([status])
  @@index([gatheringId])
}

// ----------------------------------------------------------------------------
//  Membership — a user's tier history / subscription record
// ----------------------------------------------------------------------------
model Membership {
  id              String   @id @default(cuid())
  userId          String
  tier            String   @default("NEWCOMER") // NEWCOMER | REGULAR | CURATOR | HOST
  startedAt       DateTime @default(now())
  endedAt         DateTime?
  note            String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tier])
}

// ----------------------------------------------------------------------------
//  Letter — editorial long-form essay published after a gathering
// ----------------------------------------------------------------------------
model Letter {
  id              String   @id @default(cuid())
  slug            String   @unique

  title           Json     // { ar, en }
  subtitle        Json?    // { ar, en }
  excerpt         Json     // { ar, en }
  content         Json     // { ar: "markdown...", en: "markdown..." }
  coverImageUrl   String?
  galleryUrls     String[] // ["url1", "url2", ...]
  readTimeMinutes Int      @default(5)

  publishedAt     DateTime @default(now())
  isPublished     Boolean  @default(false)

  metaTitle       Json?
  metaDescription Json?

  topicId         String
  authorHostId    String
  gatheringId     String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  topic           Topic    @relation(fields: [topicId], references: [id], onDelete: Restrict)
  authorHost      Host     @relation(fields: [authorHostId], references: [id], onDelete: Restrict)
  gathering       Gathering? @relation(fields: [gatheringId], references: [id], onDelete: SetNull)

  @@index([publishedAt])
  @@index([topicId])
}

// ----------------------------------------------------------------------------
//  Moment — a captured moment from a gathering (photo + caption)
// ----------------------------------------------------------------------------
model Moment {
  id              String   @id @default(cuid())
  gatheringId     String
  imageUrl        String
  caption         Json     // { ar, en }
  capturedByUserId String?
  capturedAt      DateTime @default(now())

  createdAt       DateTime @default(now())

  gathering       Gathering @relation(fields: [gatheringId], references: [id], onDelete: Cascade)

  @@index([gatheringId])
}

// ----------------------------------------------------------------------------
//  PrayerTime — cached daily prayer times for a city
// ----------------------------------------------------------------------------
model PrayerTime {
  id              String   @id @default(cuid())
  city            String   @default("Kuwait")
  date            DateTime @db.Date
  fajr            DateTime
  sunrise         DateTime
  dhuhr           DateTime
  asr             DateTime
  maghrib         DateTime
  isha            DateTime

  createdAt       DateTime @default(now())

  @@unique([city, date])
  @@index([city, date])
}

// ----------------------------------------------------------------------------
//  AttendeeMatch — affinity between two users (for "who you might meet")
// ----------------------------------------------------------------------------
model AttendeeMatch {
  id              String   @id @default(cuid())
  userAId         String
  userBId         String
  gatheringId     String?
  score           Float    @default(0)
  affinityTags    String[] // ["photography", "art"]
  reason          String?

  createdAt       DateTime @default(now())

  userA           User     @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB           User     @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId, gatheringId])
  @@index([userAId])
  @@index([userBId])
}

// ----------------------------------------------------------------------------
//  WaitlistEntry — overflow interest when a gathering is full
// ----------------------------------------------------------------------------
model WaitlistEntry {
  id              String   @id @default(cuid())
  userId          String
  gatheringId     String
  position        Int
  note            String?
  promotedAt      DateTime?

  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gathering       Gathering @relation(fields: [gatheringId], references: [id], onDelete: Cascade)

  @@unique([userId, gatheringId])
  @@index([gatheringId, position])
}

// ----------------------------------------------------------------------------
//  Review — feedback left after a gathering
// ----------------------------------------------------------------------------
model Review {
  id              String   @id @default(cuid())
  reviewerUserId  String
  gatheringId     String?
  hostId          String?
  rating          Int      // 1..5
  body            Json?    // { ar, en }
  isPublic        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reviewer        User     @relation("ReviewReviewer", fields: [reviewerUserId], references: [id], onDelete: Cascade)
  gathering       Gathering? @relation(fields: [gatheringId], references: [id], onDelete: SetNull)

  @@index([gatheringId])
  @@index([hostId])
}

// ----------------------------------------------------------------------------
//  Notification — in-app notification for a user
// ----------------------------------------------------------------------------
model Notification {
  id              String   @id @default(cuid())
  userId          String
  type            String   // GATHERING_REMINDER | APPLICATION_UPDATE | LETTER_PUBLISHED | ...
  payload         Json     @default("{}")
  isRead          Boolean  @default(false)
  readAt          DateTime?

  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

// ----------------------------------------------------------------------------
//  Message — direct message between two users (host <-> attendee)
// ----------------------------------------------------------------------------
model Message {
  id              String   @id @default(cuid())
  senderId        String
  receiverId      String
  body            String   @db.Text
  attachments     Json[]   @default([])
  readAt          DateTime?

  createdAt       DateTime @default(now())

  sender          User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver        User     @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([receiverId, readAt])
}
